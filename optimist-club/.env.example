# --- Required ---
# Secret used to sign session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# Prisma database URL. SQLite for development; switch to Postgres in production
# (see README "Database" section).
DATABASE_URL="file:./dev.db"

# --- Optional: Stripe (membership fee payments) ---
# When unset, the app falls back to "bank transfer" instructions for dues.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public base URL used for Stripe redirect URLs, e.g. https://optimists-club.com
APP_URL=http://localhost:3000
