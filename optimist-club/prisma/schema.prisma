// The Optimist Club — data model
//
// SQLite is used for development so the app runs with zero external services.
// For production, change `provider` to "postgresql" and set DATABASE_URL —
// no schema changes are required (string-based enums are used deliberately
// because SQLite does not support native enums).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// role:   PENDING | MEMBER | BOARD | ADMIN
// status: PENDING | ACTIVE | SUSPENDED
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("PENDING")
  status       String    @default("PENDING")
  title        String? // e.g. "Founder & CEO"
  organization String?
  bio          String?
  city         String?
  country      String?
  phone        String?
  linkedinUrl  String?
  expertise    String? // comma-separated interest/expertise tags
  memberSince  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rsvps         Rsvp[]
  payments      Payment[]
  notifications Notification[]
  announcements Announcement[]
  eventsCreated Event[]        @relation("EventCreatedBy")
  invitesMade   InviteCode[]
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  role        String    @default("MEMBER") // role granted on redemption
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  location    String
  city        String?
  startsAt    DateTime
  endsAt      DateTime?
  capacity    Int?
  isPublished Boolean   @default(false)
  createdById String
  createdBy   User      @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  rsvps       Rsvp[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// status: GOING | WAITLIST | DECLINED
model Rsvp {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  status    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, eventId])
}

// Membership dues. status: PENDING | PAID | FAILED
// method: STRIPE | TRANSFER | MANUAL
model Payment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents     Int
  currency        String    @default("eur")
  periodYear      Int // membership year the payment covers
  status          String    @default("PENDING")
  method          String    @default("TRANSFER")
  stripeSessionId String?   @unique
  paidAt          DateTime?
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, periodYear])
}

// audience: ALL | BOARD
model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  audience  String   @default("ALL")
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String? // in-app link target
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}
